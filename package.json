{
	"name": "companion-satellite",
	"version": "1.1.0",
	"main": "dist/main.js",
	"type": "module",
	"scripts": {
		"postinstall": "husky",
		"format": "prettier -w .",
		"package": "run build && companion-module-build",
		"build": "rimraf dist && run build:main",
		"build:main": "tsc -p tsconfig.build.json",
		"dev": "tsc -p tsconfig.build.json --watch",
		"lint:raw": "eslint",
		"lint": "run lint:raw ."
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bitfocus/companion-module-companion-satellite.git"
	},
	"engines": {
		"node": "^22.14",
		"yarn": "^4"
	},
	"dependencies": {
		"@companion-module/base": "~1.14.1",
		"semver": "^7.8.5",
		"ws": "^8.21.0"
	},
	"devDependencies": {
		"@companion-module/tools": "^2.7.2",
		"@types/node": "^22.20.0",
		"@types/semver": "^7.7.1",
		"@types/ws": "^8.18.1",
		"eslint": "^10.5.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"prettier": "^3.8.4",
		"rimraf": "^6.1.3",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.62.0"
	},
	"prettier": "@companion-module/tools/.prettierrc.json",
	"lint-staged": {
		"*.{css,json,md,scss}": [
			"prettier --write"
		],
		"*.{ts,tsx,js,jsx}": [
			"yarn lint:raw --fix"
		]
	},
	"packageManager": "yarn@4.17.0"
}
